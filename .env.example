# ============================================================
# Scripts_ — Root Environment Variables Reference
# Copy the relevant section into apps/api/.env or apps/web/.env.local
# ============================================================

# ── Backend (apps/api/.env) ──────────────────────────────────────────

# Supabase PostgreSQL (connection pooler + direct)
DATABASE_URL=
DIRECT_URL=

# Supabase Auth
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_TLS=true

# AI Providers
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# App
PORT=4000
NODE_ENV=production
CORS_ORIGIN=

# ── Frontend (apps/web/.env.local) ───────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=
