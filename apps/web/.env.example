# ── Supabase (public — safe to expose in browser) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Backend API ──────────────────────────────────────────────────────
# Local: http://localhost:4000  |  Production: https://your-api.onrender.com
NEXT_PUBLIC_API_URL=
