# ============================================================
# Scripts_ API — Environment Variables
# Copy to apps/api/.env and fill in your values.
# ============================================================

# ── Supabase PostgreSQL ──────────────────────────────────────────────
# Pooler URL (used by Prisma at runtime via PgBouncer)
DATABASE_URL=
# Direct connection URL (used by Prisma Migrate / db push)
DIRECT_URL=

# ── Supabase Auth ────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Token validation is done via Supabase Auth API using service role key.

# ── Upstash Redis ────────────────────────────────────────────────────
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=true

# ── AI Providers ─────────────────────────────────────────────────────
# Groq (primary) — get key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

# OpenRouter (backup) — get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# ── App ──────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
# Frontend origin for CORS (e.g. https://your-app.vercel.app)
CORS_ORIGIN=
