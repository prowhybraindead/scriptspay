# ============================================================
# Scripts_ Web — Environment Variables
# Copy to apps/web/.env.local and fill in your values.
# ============================================================

# ── Supabase (public — safe to expose in browser) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Backend API ──────────────────────────────────────────────────────
# Local: http://localhost:4000  |  Production: https://your-api.up.railway.app
# The web client auto-appends /api if missing.
NEXT_PUBLIC_API_URL=
